# Backend server port
PORT=4000

# Optional MongoDB connection string.
# Leave empty to use in-memory repository.
MONGODB_URI=

# MongoDB database name (used only when MONGODB_URI is set)
MONGODB_DB_NAME=agentic_game

# true: MongoDB connection failure will stop startup
# false: fallback to in-memory repository
MONGODB_STRICT=false

# Enable OpenAI-compatible LLM enhancement for narrative polishing
LLM_ENABLED=false

# OpenAI-compatible endpoint (Qwen via DashScope compatible API)
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# API key for compatible provider
OPENAI_API_KEY=

# Default model
OPENAI_MODEL=qwen3.5-plus

# Optional generation params
OPENAI_TEMPERATURE=0.7
OPENAI_TIMEOUT_MS=30000

# Soft timeout for one LLM polish request (ms). Exceeding this returns fallback quickly.
LLM_SOFT_TIMEOUT_MS=4000

# Circuit breaker: if consecutive failures reach this threshold, pause LLM enhancement.
LLM_MAX_CONSECUTIVE_FAILURES=2

# Circuit breaker cooldown duration (ms).
LLM_COOLDOWN_MS=180000
