# 后端服务端口
PORT=4000

# MongoDB 连接串（可选）
# 留空则使用内存仓储
MONGODB_URI=

# MongoDB 数据库名（仅在 MONGODB_URI 不为空时生效）
MONGODB_DB_NAME=agentic_game

# true：MongoDB 连接失败时阻止服务启动
# false：连接失败时自动回退到内存仓储
MONGODB_STRICT=false

# 是否启用 LLM 叙事润色
LLM_ENABLED=false

# OpenAI 兼容接口地址（默认阿里云 DashScope）
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# OpenAI 兼容接口 API Key
OPENAI_API_KEY=

# 使用的模型名称
OPENAI_MODEL=qwen-plus

# 生成参数
OPENAI_TEMPERATURE=0.7
OPENAI_TIMEOUT_MS=30000

# 单次润色软超时（毫秒），超时后立即回退规则输出
LLM_SOFT_TIMEOUT_MS=4000

# 熔断阈值：连续失败达到此次数后暂停 LLM 润色
LLM_MAX_CONSECUTIVE_FAILURES=2

# 熔断冷却时长（毫秒）
LLM_COOLDOWN_MS=180000

# ========== 火山引擎 TTS（摘要语音播报） ==========
# 控制台：语音技术 → 应用管理（拿 AppID）→ API Key 管理（拿 API Key）
# https://console.volcengine.com/speech/app
# https://console.volcengine.com/speech/new/setting/apikeys
VOLC_TTS_APPID=
VOLC_TTS_API_KEY=

# 默认经典音色集群；大模型音色（灿灿/擎苍等）改为 volcano_tts_bigtts 或 volcano_mega
VOLC_TTS_CLUSTER=volcano_tts

# 默认 BV001_streaming（通用女声）；其他音色见火山音色列表
VOLC_TTS_VOICE_TYPE=BV001_streaming

# 音频编码（mp3 / wav / pcm / ogg_opus）
VOLC_TTS_ENCODING=mp3

# 语速（0.5 ~ 2.0，默认 1.0）
VOLC_TTS_SPEED_RATIO=1.0
